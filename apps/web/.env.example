# ============================================
# JB 웹앱 환경변수 (복사 후 .env.local 로 저장)
# ============================================
# 사용 방법:
#   1) 이 파일을 복사해서 같은 폴더에 ".env.local" 이름으로 저장
#   2) 아래 값은 Supabase 대시보드에서 복사해 넣기
#   3) 저장 후 Next.js 개발 서버(npm run dev)를 한 번 재시작
#
# Supabase 값 위치:
#   Dashboard → Project Settings → API
#   - Project URL        → NEXT_PUBLIC_SUPABASE_URL
#   - anon public        → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   - service_role       → SUPABASE_SERVICE_ROLE_KEY (서버 API 전용, 브라우저에 노출 금지)
# ============================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DOC_AI_API_BASE_URL=http://localhost:8000
OPENAI_API_KEY=
